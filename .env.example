# Cisco Secure Access API credentials (OAuth 2.0 client credentials)
SECURE_ACCESS_API_KEY=your-api-key-here
SECURE_ACCESS_API_SECRET=your-api-secret-here

# Optional: Override the token endpoint.
# TOKEN_URL=https://api.sse.cisco.com/auth/v2/token

# Optional: Streamable HTTP bind settings.
# HOST=127.0.0.1
# PORT=8000

# Optional: Override the User-Agent sent on every Cisco Secure Access API
# request. The backend uses this to attribute traffic to this MCP server.
# Defaults to "secure-access-mcp-community/<version> (+<repo-url>)".
# SECURE_ACCESS_USER_AGENT=secure-access-mcp-community/0.1.0 (tenant=acme)

# ---------------------------------------------------------------------------
# Client -> server security (Streamable HTTP transport)
# ---------------------------------------------------------------------------

# REQUIRED unless MCP_ALLOW_NO_AUTH=true. Static bearer token that MCP clients
# must send as "Authorization: Bearer <token>". Use a strong, high-entropy value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# MCP_AUTH_TOKEN=replace-with-a-strong-random-token

# NOT RECOMMENDED. Run WITHOUT client->server authentication for isolated local
# testing only. Cannot be combined with MCP_AUTH_TOKEN, and is refused on any
# non-loopback HOST. Anyone who can reach the port can use your Cisco credentials.
# MCP_ALLOW_NO_AUTH=false

# Max inbound request body size in bytes (large-payload DoS protection). Default 1 MiB.
# MCP_MAX_REQUEST_BYTES=1048576

# Per-client-IP rate limit (requests/minute). 0 disables. Default 120.
# MCP_RATE_LIMIT_RPM=120

# DNS-rebinding protection (Host/Origin validation). Comma-separated allowlists.
# Defaults to the bound HOST:PORT plus loopback names.
# MCP_ALLOWED_HOSTS=mcp.internal.example:8000
# MCP_ALLOWED_ORIGINS=https://app.example.com
# MCP_DISABLE_DNS_REBINDING_PROTECTION=false   # testing only

# Two-stage commit: destructive tools require confirm=true (default true).
# SECURE_ACCESS_REQUIRE_CONFIRMATION=true

# Redact PII (identities, IPs, emails) from report/activity tool outputs. Default false.
# SECURE_ACCESS_REDACT_PII=false

# Log level for structured JSON logs written to stderr. Default INFO.
# LOG_LEVEL=INFO
